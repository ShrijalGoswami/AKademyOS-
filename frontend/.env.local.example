# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_here_run_openssl_rand_base64_32

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Supabase (from project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Sheets service account (from Service Account JSON file)
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON, escaping newlines as \n
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# Spreadsheet IDs (from the URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_HOMEWORK_SPREADSHEET_ID=your_homework_spreadsheet_id
GOOGLE_SHEETS_OFFLINE_TEST_SPREADSHEET_ID=your_offline_test_spreadsheet_id
GOOGLE_SHEETS_QUIZ_SPREADSHEET_ID=your_quiz_spreadsheet_id
# Students roster (email → year level + GATE) used by /api/ask.
# Share this sheet with GOOGLE_SHEETS_CLIENT_EMAIL (Viewer access).
GOOGLE_SHEETS_STUDENTS_SPREADSHEET_ID=your_students_spreadsheet_id

# AI Tutor Agent (server-only — NO NEXT_PUBLIC_ prefix so the key never reaches the browser)
TUTOR_AGENT_URL=https://akademy-tutor-agent.onrender.com
TUTOR_SERVICE_KEY=your_tutor_service_key_here
